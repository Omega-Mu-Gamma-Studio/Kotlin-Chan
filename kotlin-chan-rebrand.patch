+/* ══════════════════════════════════════════
+   SHIMMER MOTIF — the one flourish
+   A thin, cool-toned digital-line sweep, reserved
+   for thinking/teaching moments. Not applied globally.
+   ══════════════════════════════════════════ */
+
+.shimmer-sweep {
+  position: relative;
+  overflow: hidden;
+}
+
+.shimmer-sweep::after {
+  content: '';
+  position: absolute;
+  inset: 0;
+  pointer-events: none;
+  background: linear-gradient(
+    115deg,
+    transparent 40%,
+    rgba(185, 200, 217, 0.22) 48%,
+    rgba(255, 255, 255, 0.32) 50%,
+    rgba(185, 200, 217, 0.22) 52%,
+    transparent 60%
+  );
+  background-size: 220% 220%;
+  background-position: -140% -140%;
+  opacity: 0;
+  animation: shimmer-sweep 2.5s ease-in-out infinite;
+}
+
+@keyframes shimmer-sweep {
+  0%   { background-position: -140% -140%; opacity: 0; }
+  15%  { opacity: 0.9; }
+  55%  { background-position: 140% 140%; opacity: 0.9; }
+  70%, 100% { background-position: 140% 140%; opacity: 0; }
+}
+
+/* Dialogue bubble border shimmer on first appearance */
+.dialogue-bubble.shimmer-sweep::after {
+  border-radius: var(--radius-md);
 }
